# ---- Database ----
DATABASE_URL="postgresql://developer-playground:developer-playground@localhost:5432/developer-playground?schema=public"

# ---- Redis ----
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_URL="redis://localhost:6379"

# ---- API ----
API_PORT="4000"
PORTAL_JWT_SECRET="change-me-in-production-portal-jwt-secret"
PORTAL_JWT_EXPIRES_IN="1d"

# AES-256-GCM key for encrypting credentials/webhook secrets at rest (32-byte hex)
CREDENTIAL_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Public base URL used when generating runtime / webhook-receiver URLs
PUBLIC_BASE_URL="http://localhost:4000"

# Comma-separated CIDR ranges explicitly allowed as webhook targets (SSRF guard). Empty = block all private ranges.
WEBHOOK_ALLOWED_PRIVATE_CIDRS=""

# Max inbound JSON body size
MAX_JSON_BODY_BYTES="1048576"

# ---- Worker ----
WORKER_CONCURRENCY="5"

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
