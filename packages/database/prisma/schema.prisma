// Developer Playground — Prisma schema (MVP scope)
// This is the shared data contract for the API, worker, and seed scripts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & workspace
// ---------------------------------------------------------------------------

model User {
  id           String            @id @default(uuid())
  email        String            @unique
  name         String
  passwordHash String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  memberships  WorkspaceMember[]
  auditLogs    AuditLog[]
}

model Workspace {
  id        String            @id @default(uuid())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  members            WorkspaceMember[]
  integrationSystems IntegrationSystem[]
  auditLogs          AuditLog[]
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(DEVELOPER)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// ---------------------------------------------------------------------------
// Integration systems, environments, endpoints
// ---------------------------------------------------------------------------

model IntegrationSystem {
  id             String       @id @default(uuid())
  workspaceId    String
  name           String
  slug           String
  description    String?
  basePath       String?
  status         SystemStatus @default(ACTIVE)
  defaultHeaders Json?
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  environments Environment[]

  @@unique([workspaceId, slug])
}

model Environment {
  id                  String   @id @default(uuid())
  integrationSystemId String
  name                String
  slug                String
  isActive            Boolean  @default(true)
  variables           Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  integrationSystem IntegrationSystem      @relation(fields: [integrationSystemId], references: [id], onDelete: Cascade)
  endpoints         ApiEndpoint[]
  webhooks          Webhook[]
  credentials       ApiCredential[]
  inboundEndpoints  InboundWebhookEndpoint[]
  requestLogs       RequestLog[]

  @@unique([integrationSystemId, slug])
}

model ApiEndpoint {
  id                  String       @id @default(uuid())
  environmentId       String
  name                String
  method              HttpMethod
  path                String
  description         String?
  authType            AuthType     @default(NONE)
  headersConfig       Json?        // array of header param definitions
  queryConfig         Json?        // array of query param definitions
  pathParamsConfig    Json?        // array of path param definitions
  requestSchema       Json?        // JSON Schema for the request body
  responseMode        ResponseMode @default(STATIC)
  defaultStatusCode   Int          @default(200)
  defaultHeaders      Json?
  defaultResponseBody Json?
  delayMs             Int          @default(0)
  timeoutEnabled      Boolean      @default(false)
  isActive            Boolean      @default(true)
  version             Int          @default(1)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  environment    Environment           @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  rules          ResponseRule[]
  webhooks       Webhook[]
  requestLogs    RequestLog[]
  sequenceState  EndpointSequenceState?

  @@unique([environmentId, method, path])
  @@index([environmentId, isActive])
}

model ResponseRule {
  id         String   @id @default(uuid())
  endpointId String
  name       String
  priority   Int
  conditions Json     // array of { source, operator, value }
  response   Json     // { statusCode, headers, body }
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  endpoint ApiEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, priority])
}

model EndpointSequenceState {
  id         String   @id @default(uuid())
  endpointId String   @unique
  cursor     Int      @default(0)
  updatedAt  DateTime @updatedAt

  endpoint ApiEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Credentials
// ---------------------------------------------------------------------------

model ApiCredential {
  id            String         @id @default(uuid())
  environmentId String
  name          String
  type          AuthType       @default(API_KEY)
  // For API_KEY/BEARER: hash of the token. For BASIC: username stored, secret hashed. For HMAC: encrypted secret.
  keyPrefix     String?        // shown in the UI, e.g. "sandbox_key_ab12"
  secretHash    String?        // bcrypt/argon hash for verification
  encryptedSecret String?      // AES-GCM encrypted (only for HMAC signing verification)
  username      String?        // for BASIC
  status        CredentialStatus @default(ACTIVE)
  lastUsedAt    DateTime?
  createdAt     DateTime       @default(now())
  revokedAt     DateTime?

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([environmentId, status])
}

// ---------------------------------------------------------------------------
// Webhooks (outbound)
// ---------------------------------------------------------------------------

model Webhook {
  id                  String        @id @default(uuid())
  environmentId       String
  endpointId          String?
  name                String
  targetUrl           String
  method              HttpMethod    @default(POST)
  headers             Json?
  payloadTemplate     Json?
  triggerEvent        String?
  delayMs             Int           @default(0)
  retryEnabled        Boolean       @default(true)
  maxRetries          Int           @default(5)
  signatureType       SignatureType @default(NONE)
  encryptedSecret     String?       // AES-GCM encrypted signing secret
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  environment Environment       @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  endpoint    ApiEndpoint?      @relation(fields: [endpointId], references: [id], onDelete: SetNull)
  deliveries  WebhookDelivery[]
}

model WebhookDelivery {
  id             String         @id @default(uuid())
  webhookId      String
  requestLogId   String?
  idempotencyKey String         @unique
  event          String?
  targetUrl      String
  attempt        Int            @default(0)
  maxRetries     Int            @default(5)
  status         DeliveryStatus @default(PENDING)
  requestPayload Json?
  requestHeaders Json?
  responseStatus Int?
  responseBody   String?
  responseTimeMs Int?
  errorMessage   String?
  nextRetryAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  webhook    Webhook     @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  requestLog RequestLog? @relation(fields: [requestLogId], references: [id], onDelete: SetNull)

  @@index([webhookId, status])
}

// ---------------------------------------------------------------------------
// Inbound webhook receiver
// ---------------------------------------------------------------------------

model InboundWebhookEndpoint {
  id            String   @id @default(uuid())
  environmentId String
  name          String
  slug          String
  expectedSignatureType SignatureType @default(NONE)
  encryptedSecret String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  environment Environment         @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  logs        InboundWebhookLog[]

  @@unique([environmentId, slug])
}

model InboundWebhookLog {
  id                String   @id @default(uuid())
  inboundEndpointId String
  method            String
  url               String
  headers           Json?
  query             Json?
  body              Json?
  contentType       String?
  sourceIp          String?
  signatureValid    Boolean?
  processingStatus  String   @default("RECEIVED")
  receivedAt        DateTime @default(now())

  inboundEndpoint InboundWebhookEndpoint @relation(fields: [inboundEndpointId], references: [id], onDelete: Cascade)

  @@index([inboundEndpointId, receivedAt])
}

// ---------------------------------------------------------------------------
// Request logs & audit
// ---------------------------------------------------------------------------

model RequestLog {
  id             String   @id @default(uuid())
  environmentId  String
  endpointId     String?
  correlationId  String
  method         String
  path           String
  statusCode     Int
  authOk         Boolean  @default(true)
  validationOk   Boolean  @default(true)
  matchedRuleId  String?
  matchedRuleName String?
  requestHeaders Json?
  requestQuery   Json?
  requestParams  Json?
  requestBody    Json?
  responseHeaders Json?
  responseBody   Json?
  responseTimeMs Int      @default(0)
  sourceIp       String?
  createdAt      DateTime @default(now())

  environment Environment       @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  endpoint    ApiEndpoint?      @relation(fields: [endpointId], references: [id], onDelete: SetNull)
  deliveries  WebhookDelivery[]

  @@index([environmentId, createdAt])
  @@index([correlationId])
}

model AuditLog {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum WorkspaceRole {
  OWNER
  ADMIN
  DEVELOPER
  QA
  VIEWER
}

enum SystemStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum AuthType {
  NONE
  API_KEY
  BASIC
  BEARER
  HMAC
}

enum ResponseMode {
  STATIC
  RULE_BASED
  RANDOM
  SEQUENCE
  SCRIPTED
}

enum SignatureType {
  NONE
  HMAC_SHA256
  CUSTOM_HEADER
}

enum CredentialStatus {
  ACTIVE
  REVOKED
}

enum DeliveryStatus {
  PENDING
  DELIVERING
  SUCCESS
  FAILED
  RETRYING
}
