{
  "name": "developer-playground",
  "version": "0.1.0",
  "private": true,
  "description": "Developer Playground — Dynamic API Integration Sandbox",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @developer-playground/database generate",
    "db:migrate": "pnpm --filter @developer-playground/database migrate",
    "db:seed": "pnpm --filter @developer-playground/database seed"
  },
  "engines": {
    "node": ">=20"
  }
}
